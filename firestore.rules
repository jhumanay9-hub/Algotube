
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ALGOTUBE SECURITY RULES - PRODUCTION GRADE
     * Explicitly allows collection listing and document fetching for public content.
     */

    // --- VIDEOS COLLECTION ---
    match /videos/{videoId} {
      // Explicitly allow discovery (list) and individual playback (get)
      allow get, list: if true;
      
      // Allow any authenticated user to upload (create) or record engagement (update)
      // Engagement includes likesCount, viewsCount, and hydrating mock documents
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      
      // Only the uploader can delete their own transmission
      allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;
      
      // Nested Comments
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }
    }

    // --- USER PROFILES ---
    match /userProfiles/{userId} {
      // Discovery is public for channel pages
      allow read: if true;
      
      // Users manage their own identity and social metadata
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null; // Allows incrementing sub counts
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Private User Data (History, Likes, Subscriptions)
      // These are scoped per user to ensure privacy
      match /videoInteractions/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /subscriptions/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /history/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
