
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ALGOTUBE SECURITY RULES - PRODUCTION GRADE
     * Explicitly allows collection listing and document fetching for public content.
     */

    // --- VIDEOS COLLECTION ---
    match /videos/{videoId} {
      // allow read is a shortcut for get and list. 
      // We set it to true to ensure the Home feed (list) and Video page (get) always work.
      allow read: if true;
      
      // Allow any authenticated user to create (upload) or update (engagement metrics)
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      
      // Only the original uploader can delete their transmission
      allow delete: if request.auth != null && resource.data.uploaderId == request.auth.uid;

      // Nested Comments
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }
    }

    // --- USER PROFILES ---
    match /userProfiles/{userId} {
      // Discovery is public
      allow read: if true;
      
      // Users manage their own identity
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null; // Broad update to allow social counters (subs)
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Private User Data
      match /videoInteractions/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /subscriptions/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /history/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
