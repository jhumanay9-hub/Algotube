
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ALGOTUBE SECURITY RULES
     * Standardized rules for public discovery and authenticated interaction.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- VIDEOS ---
    match /videos/{videoId} {
      // Allow public read access (get and list) for all videos
      allow read: if true;
      
      // Allow any signed-in user to create/upload a video
      allow create: if isSignedIn();
      
      // Allow any signed-in user to update engagement metrics (likes, views, etc.)
      // We allow this broad update for the MVP to handle interaction transactions easily.
      allow update: if isSignedIn();
      
      // Only the uploader can delete their video
      allow delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;

      // Comments are nested under videos
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }

    // --- USER PROFILES ---
    match /userProfiles/{userId} {
      // Profiles are public for discovery
      allow read: if true;
      
      // Users can only create their own profile document
      allow create: if isOwner(userId);
      
      // Allow owners to edit, or others to increment subscriberCount via social logic
      allow update: if isOwner(userId) || isSignedIn();
      
      allow delete: if isOwner(userId);

      // Private User Data Sub-collections
      match /videoInteractions/{interactionId} {
        allow read, write: if isOwner(userId);
      }

      match /subscriptions/{creatorId} {
        allow read, write: if isOwner(userId);
      }
      
      match /history/{videoId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
