
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ALGOTUBE SECURITY RULES
     * Ensures public read access for community content and private access for user data.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COMMUNITY VIDEOS ---
    match /videos/{videoId} {
      // Explicitly allow both individual read and collection listing for everyone
      allow get, list: if true;
      
      // Allow signed-in users to upload
      allow create: if isSignedIn();
      
      // Allow signed-in users to update (likes, dislikes, views)
      // For MVP, we allow authenticated updates to the video document.
      allow update: if isSignedIn();
      
      // Only uploader can delete their transmission
      allow delete: if isSignedIn() && (resource.data.uploaderId == request.auth.uid);

      match /comments/{commentId} {
        allow get, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
      }
    }

    // --- USER PROFILES & PRIVATE DATA ---
    match /userProfiles/{userId} {
      // Profiles are public for discovery
      allow get, list: if true;
      
      // Users can only create their own profile
      allow create: if isOwner(userId);
      
      // Allow owners to edit profile, or others to increment subscriberCount
      allow update: if isOwner(userId) || isSignedIn();
      
      allow delete: if isOwner(userId);

      // Private sub-collections
      match /videoInteractions/{interactionId} {
        allow read, write: if isOwner(userId);
      }

      match /subscriptions/{creatorId} {
        allow read, write: if isOwner(userId);
      }
      
      match /history/{videoId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
