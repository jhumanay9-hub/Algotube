
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ALGOTUBE SECURITY RULES - PRODUCTION READY
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    match /userProfiles/{userId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isOwner(userId);
      // Allow anyone signed in to update engagement metrics (subscriberCount) 
      // while owner can update everything.
      allow update: if isOwner(userId) || isSignedIn();
      allow delete: if isOwner(userId);

      match /videoInteractions/{interactionId} {
        allow read, write: if isOwner(userId);
      }

      match /subscriptions/{creatorId} {
        allow read, write: if isOwner(userId);
      }
      
      match /history/{videoId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /videos/{videoId} {
      allow get, list: if true;
      // Allow signed-in users to create video metadata (supports mock hydration)
      allow create: if isSignedIn();
      // Allow uploader to update everything, or signed-in users to update engagement metrics
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;

      match /comments/{commentId} {
        allow get, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
      }
    }
  }
}
