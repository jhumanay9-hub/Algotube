
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ALGOTUBE SECURITY RULES DOCUMENTATION
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDataOwner(ownerField) {
      return isSignedIn() && request.auth.uid == ownerField;
    }

    // --- COLLECTION RULES ---

    match /userProfiles/{userId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isOwner(userId);
      // Allow the owner to update anything, or others to increment subscriberCount
      allow update: if isOwner(userId) || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['subscriberCount']));
      allow delete: if isOwner(userId);

      match /videoInteractions/{interactionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /subscriptions/{creatorId} {
        allow get, list: if isOwner(userId);
        allow create, delete: if isOwner(userId);
      }
      
      match /history/{videoId} {
        allow get, list, write: if isOwner(userId);
      }
    }

    match /videos/{videoId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      // Allow uploader to update everything, or others to update engagement metrics
      allow update: if isDataOwner(resource.data.uploaderId) || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'dislikesCount', 'commentsCount', 'shareCount', 'viewsCount']));
      allow delete: if isDataOwner(resource.data.uploaderId);

      match /comments/{commentId} {
        allow get, list: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if isDataOwner(resource.data.userId) || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'dislikesCount']));
        allow delete: if isDataOwner(resource.data.userId);
      }
    }
  }
}
